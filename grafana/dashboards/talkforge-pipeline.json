  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Pipeline Overview",
      "type": "row"
    },
    {
      "id": 1,
      "title": "Recent Traces",
      "description": "Recent TalkForge traces with links to full trace view",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "nativeSearch",
          "serviceName": "slidewreck",
          "limit": 10,
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Workflow Run Count",
      "description": "Number of workflow runs over time",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(traces_spanmetrics_calls_total{service=\"slidewreck\", span_name=~\"invoke_workflow.*\"}[$__rate_interval])",
          "legendFormat": "{{span_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 80 }
        }
      }
    },
    {
      "id": 2,
      "title": "Workflow Run Duration (p50 / p95)",
      "description": "End-to-end workflow run latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.5, sum(rate(traces_spanmetrics_latency_bucket{service=\"slidewreck\", span_name=~\"invoke_workflow.*\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(traces_spanmetrics_latency_bucket{service=\"slidewreck\", span_name=~\"invoke_workflow.*\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        }
      }
