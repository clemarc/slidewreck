{
  "name": "bmad-mastra-presentation",
  "version": "1.0.0",
  "description": "Mastra agents to build presentations using BMAD and Claude Code",
  "scripts": {
    "dev": "concurrently --names mastra,web --prefix-colors blue,green \"mastra dev\" \"pnpm --filter web dev\"",
    "dev:mastra": "mastra dev",
    "dev:web": "pnpm --filter web dev",
    "build": "mastra build",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "eval": "npx tsx --env-file=.env src/eval.ts",
    "render-deck": "npx tsx scripts/render-deck.ts",
    "db:reset": "npx tsx --env-file=.env scripts/db-reset.ts",
    "db:reset:tables": "npx tsx --env-file=.env scripts/db-reset.ts --tables",
    "db:reset:vectors": "npx tsx --env-file=.env scripts/db-reset.ts --vectors"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/provider-utils": "^4.0.19",
    "@mastra/core": "^1.13.2",
    "@mastra/observability": "^1.5.0",
    "@mastra/pg": "^1.8.0",
    "@mastra/rag": "^2.1.2",
    "ai": "^6.0.116",
    "pg": "^8.20.0",
    "unpdf": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@marp-team/marp-core": "^4.3.0",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@types/node": "^25.5.0",
    "concurrently": "^9.1.2",
    "mastra": "^1.3.12",
    "puppeteer": "^24.39.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "puppeteer",
      "sharp"
    ]
  }
}
