{
  "name": "bmad-mastra-presentation",
  "version": "1.0.0",
  "description": "Mastra agents to build presentations using BMAD and Claude Code",
  "scripts": {
    "dev": "concurrently --names mastra,web --prefix-colors blue,green \"pnpm --filter slidewreck dev\" \"pnpm --filter web dev\"",
    "dev:mastra": "pnpm --filter slidewreck dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm --filter slidewreck build",
    "test": "pnpm -r test",
    "test:integration": "pnpm --filter web test:integration",
    "typecheck": "pnpm -r typecheck",
    "eval": "pnpm --filter slidewreck eval",
    "render-deck": "pnpm --filter slidewreck render-deck",
    "db:reset": "pnpm --filter slidewreck db:reset",
    "db:reset:tables": "pnpm --filter slidewreck db:reset:tables",
    "db:reset:vectors": "pnpm --filter slidewreck db:reset:vectors"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "puppeteer", "sharp"]
  }
}
