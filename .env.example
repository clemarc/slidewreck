ANTHROPIC_API_KEY=your-anthropic-api-key-here
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/talkforge

# Web search provider: anthropic (default), openai, or google
# Anthropic uses ANTHROPIC_API_KEY (already configured above)
# OpenAI requires @ai-sdk/openai package + OPENAI_API_KEY
# Google requires @ai-sdk/google package + GOOGLE_GENERATIVE_AI_API_KEY
WEB_SEARCH_PROVIDER=anthropic
